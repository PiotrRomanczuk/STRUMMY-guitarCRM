meta {
  name: put-song-update
  type: http
  seq: 27
}

put {
  url: {{baseUrl}}/api/song/update
  body: json
  auth: inherit
}

body:json {
  {
    "id": "{{sample_song_id}}",
    "title": "Wonderwall",
    "author": "Oasis"
  }
}

tests {
  test('Status 200 or 404', function() {
    expect([200, 404, 422]).to.include(res.status);
  });
}