meta {
  name: put-song
  type: http
  seq: 26
}

put {
  url: {{baseUrl}}/api/song
  body: json
  auth: inherit
}

body:json {
  {
    "id": "{{sample_song_id}}",
    "title": "Wonderwall (Updated)",
    "author": "Oasis",
    "level": "beginner",
    "key": "Em"
  }
}

tests {
  test('Status 200', function() {
    expect(res.status).to.equal(200);
  });
}