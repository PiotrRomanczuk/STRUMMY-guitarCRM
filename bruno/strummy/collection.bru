headers {
  Content-Type: application/json
  Accept: application/json
}

auth {
  mode: bearer
}

auth:bearer {
  token: {{authToken}}
}

script:pre-request {
  // Collection-level: acquire a Supabase JWT for the active persona.
  // Personas are selected via the `persona` env var: admin | teacher | student.
  // Tokens are cached on the Bruno env for the run.
  const persona = bru.getEnvVar('persona') || 'admin';
  const tokenKey = `authToken_${persona}`;
  const expKey = `authTokenExp_${persona}`;

  const cached = bru.getVar(tokenKey);
  const exp = Number(bru.getVar(expKey) || 0);
  const now = Math.floor(Date.now() / 1000);

  if (cached && exp - 30 > now) {
    bru.setVar('authToken', cached);
    return;
  }

  const supabaseUrl = bru.getEnvVar('SUPABASE_URL');
  const supabaseAnon = bru.getEnvVar('SUPABASE_ANON_KEY');
  const email = bru.getEnvVar(`${persona.toUpperCase()}_EMAIL`);
  const password = bru.getEnvVar(`${persona.toUpperCase()}_PASSWORD`);

  if (!supabaseUrl || !supabaseAnon || !email || !password) {
    throw new Error(`Missing Supabase auth env vars for persona=${persona}. ` +
      'Set SUPABASE_URL, SUPABASE_ANON_KEY, <PERSONA>_EMAIL, <PERSONA>_PASSWORD.');
  }

  const res = await fetch(`${supabaseUrl}/auth/v1/token?grant_type=password`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      apikey: supabaseAnon,
    },
    body: JSON.stringify({ email, password }),
  });

  if (!res.ok) {
    const body = await res.text();
    throw new Error(`Supabase sign-in failed for ${persona} (${res.status}): ${body}`);
  }

  const json = await res.json();
  const accessToken = json.access_token;
  const expiresAt = Math.floor(Date.now() / 1000) + (json.expires_in || 3600);

  bru.setVar(tokenKey, accessToken);
  bru.setVar(expKey, String(expiresAt));
  bru.setVar('authToken', accessToken);
}

tests {
  test('Response is not 5xx', function() {
    expect(res.status, `5xx from ${req.url}`).to.be.below(500);
  });
}
