meta {
  name: get-lessons-analytics
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/lessons/analytics
  auth: inherit
}

tests {
  test('Status 200', function() {
    expect(res.status).to.equal(200);
  });
  test('Has totalLessons or completionRate', function() {
    expect(res.body).to.satisfy(function(b) {
      return b.hasOwnProperty('totalLessons') || b.hasOwnProperty('completionRate');
    });
  });
}